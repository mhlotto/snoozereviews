<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:navigationIcon="@drawable/abc_ic_ab_back_material"
            app:titleTextColor="?attr/colorOnSurface" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/loading_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_screen"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/loading_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:text="@string/loading_sleep_log"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/error_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_screen"
                android:visibility="gone">

                <TextView
                    android:id="@+id/error_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/form_load_error_title"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.Headline"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/error_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:gravity="center"
                    android:text="@string/form_load_error_message"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/retry_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/retry" />
            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/form_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="false">

                <LinearLayout
                    android:id="@+id/form_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_screen">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/form_section_date"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/night_date_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:hint="@string/night_date_label">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/night_date_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="false"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_screen"
                        android:text="@string/form_section_location"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/location_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/chip_spacing_horizontal"
                        app:chipSpacingVertical="@dimen/chip_spacing_vertical"
                        android:layout_marginTop="@dimen/spacing_small"
                        app:singleSelection="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_screen"
                        android:text="@string/form_section_times"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                        android:textColor="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/fell_asleep_button"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="@dimen/touch_target_min" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clear_fell_asleep_button"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/clear_time" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/woke_up_button"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_small"
                            android:minHeight="@dimen/touch_target_min" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clear_woke_up_button"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/clear_time" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_screen"
                        android:text="@string/form_section_questions"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/slept_through_question"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/slept_through_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/chip_spacing_horizontal"
                        app:chipSpacingVertical="@dimen/chip_spacing_vertical"
                        app:singleSelection="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/had_dreams_question"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/had_dreams_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/chip_spacing_horizontal"
                        app:chipSpacingVertical="@dimen/chip_spacing_vertical"
                        app:singleSelection="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_screen"
                        android:text="@string/form_section_ratings"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/sleep_rating_label"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/sleep_rating_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/chip_spacing_horizontal"
                        app:chipSpacingVertical="@dimen/chip_spacing_vertical"
                        app:singleSelection="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:text="@string/rested_rating_label"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/rested_rating_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/chip_spacing_horizontal"
                        app:chipSpacingVertical="@dimen/chip_spacing_vertical"
                        app:singleSelection="true" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/awakening_count_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:hint="@string/awakening_count_label">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/awakening_count_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_screen"
                        android:text="@string/form_section_tags"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                        android:textColor="?attr/colorOnSurface" />

                    <LinearLayout
                        android:id="@+id/tag_sections_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:orientation="vertical" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_screen"
                        android:text="@string/form_section_notes"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/notes_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:hint="@string/notes_label">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/notes_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top|start"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="4" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/save_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:textAppearance="@style/TextAppearance.SnoozeReviews.Supporting"
                        android:textColor="?attr/colorError"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/save_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:minHeight="@dimen/touch_target_min"
                        android:text="@string/save_sleep_log" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/save_progress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:indeterminate="true"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
