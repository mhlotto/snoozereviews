<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:navigationIcon="@drawable/abc_ic_ab_back_material"
            app:title="@string/descriptive_tags"
            app:titleTextColor="?attr/colorOnSurface" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_screen">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tag_category_other"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                    android:textColor="?attr/colorOnSurface"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/form_section_tags"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="@string/settings_builtin_tags_message"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.Supporting"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <LinearLayout
                    android:id="@+id/builtin_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:orientation="vertical" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_screen"
                    android:text="@string/settings_active_custom_tags"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tag_name_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:hint="@string/settings_tag_name_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tag_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/category_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:minHeight="@dimen/touch_target_min" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/add_tag_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:minHeight="@dimen/touch_target_min"
                    android:text="@string/settings_add_tag" />

                <TextView
                    android:id="@+id/active_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:text="@string/settings_custom_tags_empty"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <LinearLayout
                    android:id="@+id/active_custom_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_screen"
                    android:text="@string/settings_removed_custom_tags"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.SectionTitle"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/removed_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:text="@string/settings_removed_tags_empty"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <LinearLayout
                    android:id="@+id/removed_custom_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tag_settings_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:textAppearance="@style/TextAppearance.SnoozeReviews.Body"
                    android:textColor="?attr/colorError"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
