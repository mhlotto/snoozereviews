<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SnoozeReviews" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/snooze_primary</item>
        <item name="colorOnPrimary">@color/snooze_on_primary</item>
        <item name="colorSurface">@color/snooze_surface</item>
        <item name="colorOnSurface">@color/snooze_on_surface</item>
        <item name="colorSurfaceVariant">@color/snooze_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/snooze_on_surface_variant</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/snooze_surface</item>
        <item name="android:navigationBarColor">@color/snooze_surface</item>
    </style>

    <!-- Temporary launcher-icon artwork; final Snooze Reviews splash art will replace it later. -->
    <style name="Theme.SnoozeReviews.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/snooze_surface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.SnoozeReviews</item>
    </style>

    <style name="DetailRowText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/spacing_small</item>
        <item name="android:textAppearance">?attr/textAppearanceBodyLarge</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
</resources>
